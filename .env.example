# Copy this file to .env and fill in real values.

# Leave as-is for local SQLite (default, zero setup).
# For Postgres later (Supabase / Neon free tier), use something like:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./hungermap.db

# Used only by the AI developer's code in app/ai_triage.py
ANTHROPIC_API_KEY=your-key-here
