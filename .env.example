# Copy to .env and fill in as needed. All values are optional for local dev.

# --- Database -------------------------------------------------------------
# Defaults to a local SQLite file if unset. For Postgres (Supabase/Neon):
#   DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_URL=sqlite:///./hungermap.db

# --- AI triage (Groq) -----------------------------------------------------
# If GROQ_API_KEY is set, run_ai_triage() calls Groq. Otherwise it uses a
# built-in deterministic rule-based fallback (no key needed).
# Get a free key at https://console.groq.com/keys
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
# GROQ_MODEL=llama-3.3-70b-versatile
